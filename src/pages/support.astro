---
import Base from '../layouts/Base.astro';
---

<Base title="Support the Garden" description="Volunteer, donate, or learn about the North Alabama Japanese Garden Foundation.">
  <section class="section">
    <div class="page-container content-width">
      <h1>Support the Garden</h1>
      <p>
        The North Alabama Japanese Garden is maintained entirely through
        volunteer labor and community support. The North Alabama Japanese
        Garden Foundation (NAJGF) coordinates the garden's care and
        programming.
      </p>
    </div>
  </section>

  <section class="section" id="volunteer">
    <div class="page-container">
      <div class="feature-block">
        <div>
          <h2 style="margin-top: 0;">Volunteer</h2>
          <p>
            The garden needs hands. Volunteer workdays include path
            maintenance, pruning, planting, and general cleanup. During
            festivals, volunteers help with setup, event coordination,
            and welcoming visitors.
          </p>
          <p>
            No gardening experience required. The best way to get involved
            is to reach out through our Facebook page or email.
          </p>
          <div style="margin-top: var(--space-md);">
            <a href="https://www.facebook.com/NorthAlabamaJapaneseGarden" target="_blank" rel="noopener" class="btn">
              Facebook
            </a>
            <a href="mailto:info@northalabamajapanesegarden.org" class="btn" style="margin-left: var(--space-xs);">
              Email Us
            </a>
          </div>
        </div>
        <div>
          <div class="placeholder-image" style="aspect-ratio: 4/3; border-radius: 2px;">
            Volunteer workday photo
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="donate" style="background-color: var(--color-cream);">
    <div class="page-container content-width">
      <h2 style="margin-top: 0;">Donate</h2>
      <p>
        Donations support garden maintenance, new plantings, trail
        construction, and cultural programming. The Foundation is working
        toward 501(c)(3) nonprofit status.
      </p>
      <!-- Zeffy donation embed goes here -->
      <div
        class="placeholder-image"
        style="width: 100%; min-height: 300px; margin-top: var(--space-md); border-radius: 2px;"
      >
        Zeffy donation form embed
      </div>
      <p style="font-size: 0.875rem; color: var(--color-stone); margin-top: var(--space-sm);">
        <!-- Replace with Zeffy embed code once account is set up -->
        <!-- <iframe src="https://www.zeffy.com/embed/..." ...></iframe> -->
      </p>
    </div>
  </section>

  <section class="section" id="about">
    <div class="page-container content-width">
      <h2>About the Foundation</h2>
      <p>
        The North Alabama Japanese Garden Foundation (NAJGF) was established
        to maintain and improve the garden, coordinate cultural programming,
        and grow the garden's reach in the Huntsville community.
      </p>
      <p>
        <strong>Executive Director:</strong> Sumie Sanders<br />
        <strong>Email:</strong>
        <a href="mailto:info@northalabamajapanesegarden.org">info@northalabamajapanesegarden.org</a>
      </p>
    </div>
  </section>

  <section class="section" id="sponsors" style="background-color: var(--color-cream);">
    <div class="page-container content-width">
      <h2 style="margin-top: 0;">Our Sponsors &amp; Partners</h2>
      <p>
        The garden exists because of the generosity of its sponsors and the
        labor of its volunteers. We are grateful to:
      </p>

      <h3>Lead Sponsor</h3>
      <div class="sponsor-grid">
        <div class="sponsor-grid__item"><strong>Mazda Toyota Manufacturing (MTM)</strong></div>
      </div>

      <h3>Sponsors</h3>
      <div class="sponsor-grid">
        <div class="sponsor-grid__item">Daikin Alabama</div>
        <div class="sponsor-grid__item">Toyota Motor Manufacturing Alabama</div>
        <div class="sponsor-grid__item">Bill Penney Toyota</div>
      </div>

      <h3>Partners</h3>
      <div class="sponsor-grid">
        <div class="sponsor-grid__item">Japan-America Society of Alabama</div>
        <div class="sponsor-grid__item">Consulate General of Japan in Atlanta</div>
        <div class="sponsor-grid__item">University of Alabama in Huntsville</div>
        <div class="sponsor-grid__item">Lockheed Martin</div>
      </div>

      <p style="font-size: 0.875rem; color: var(--color-stone); margin-top: var(--space-lg);">
        Interested in supporting the garden as a sponsor?
        <a href="mailto:info@northalabamajapanesegarden.org">Contact us</a>.
      </p>
    </div>
  </section>
</Base>
